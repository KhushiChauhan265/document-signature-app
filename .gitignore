# Dependency folders
node_modules/
**/node_modules/

# Production builds
dist/
build/

# Env files (contains private passwords & keys)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS and IDE files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Ignore actual uploaded files, but keep the directory template
backend/uploads/*
!backend/uploads/.gitkeep

# Ignore actual generated signed PDFs
backend/signed-pdfs/*
!backend/signed-pdfs/.gitkeep
