# Server Configuration
PORT=5000

# Database Connection (MongoDB)
# Change this to your local or Atlas MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/document_signature_db

# Security Token Secrets
# Replace this with a long, random secret key in production
JWT_SECRET=your_jwt_signing_secret_key_here

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
